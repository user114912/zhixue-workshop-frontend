            源自<em>社区</em>，连接<em>世界</em>。
          </p>
          <div class="footer-pulse" id="footer-pulse" data-hidden="true" aria-live="polite">
            <span class="footer-pulse-dot" aria-hidden="true"></span>
            最新：
            <a class="footer-pulse-tag" data-pulse="release-link" href="https://github.com/HKUDS/DeepTutor/releases" target="_blank" rel="noopener">
              <span data-pulse="release-tag">—</span>
            </a>
            <span class="sep">·</span>
            <span class="num"><span data-pulse="requests">—</span> 次浏览</span>
          </div>
        </div>

        <div class="footer-fine">
          <span>
            © 2026 <a href="https://github.com/HKUDS" target="_blank" rel="noopener">
              港大数据智能实验室
            </a>
          </span>
          <span>基于 Apache 2.0 协议发布</span>
        </div>
      </footer>

      <script is:inline>
        (async () => {
          const pulse = document.getElementById("footer-pulse");
          if (!pulse) return;

          const fmtNum = (n) => {
            if (n == null) return "0";
            if (n >= 1e9) return (n / 1e9).toFixed(2).replace(/\.?0+$/, "") + "B";
            if (n >= 1e6) return (n / 1e6).toFixed(2).replace(/\.?0+$/, "") + "M";
            if (n >= 1e3) return (n / 1e3).toFixed(2).replace(/\.?0+$/, "") + "k";
            return String(n);
          };
          const fmtBytes = (b) => {
            if (b == null) return "0 B";
            const KB = 1024, MB = KB * 1024, GB = MB * 1024, TB = GB * 1024;
            if (b >= TB) return (b / TB).toFixed(2) + " TB";
            if (b >= GB) return (b / GB).toFixed(2) + " GB";
            if (b >= MB) return (b / MB).toFixed(2) + " MB";
            if (b >= KB) return (b / KB).toFixed(2) + " KB";
            return b + " B";
          };
          const setText = (key, value) => {
            const el = pulse.querySelector('[data-pulse="' + key + '"]');
            if (el) el.textContent = value;
          };

          const isLocal =
            location.hostname === "localhost" ||
            location.hostname === "127.0.0.1" ||
            location.hostname === "0.0.0.0";

          const sample = isLocal
            ? {
                traffic: {
                  window: "total",
                  requests: 78400,
                  bytes: 1530000000,
                  uniques: 18200,
                },
                release: {
                  tag: "v1.4.0-beta",
                  name: "v1.4.0-beta",
                  url: "https://github.com/HKUDS/DeepTutor/releases/tag/v1.4.0-beta",
                  published_at: "2026-05-21T00:00:00Z",
                  prerelease: true,
                },
              }
            : null;

          const [traffic, release] = await Promise.allSettled([
            isLocal
              ? Promise.resolve(sample.traffic)
              : fetch("/api/traffic", { cache: "no-store" }).then((r) =>
                  r.ok ? r.json() : Promise.reject(new Error("status=" + r.status)),
                ),
            isLocal
              ? Promise.resolve(sample.release)
              : fetch("/api/release", { cache: "no-store" }).then((r) =>
                  r.ok ? r.json() : Promise.reject(new Error("status=" + r.status)),
                ),
          ]);

          let trafficOK = false;
          let releaseOK = false;

          if (traffic.status === "fulfilled" && traffic.value && !traffic.value.error) {
            setText("requests", fmtNum(traffic.value.requests));
            setText("bytes", fmtBytes(traffic.value.bytes));
            trafficOK = true;
          }
          if (release.status === "fulfilled" && release.value && !release.value.error) {
            setText("release-tag", release.value.tag);
            const link = pulse.querySelector('[data-pulse="release-link"]');
            if (link && release.value.url) link.setAttribute("href", release.value.url);
            releaseOK = true;
          }

          if (releaseOK || trafficOK) {
            pulse.setAttribute("data-hidden", "false");
          }
        })();
      </script>
