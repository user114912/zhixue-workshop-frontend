---
import "../../styles/global.css";

const features = [
  {
    chapter: "I",
    title: "聊天工作台",
    body: "五种模式 —— Chat / Solve / Quiz / Research / Visualize —— 共享同一个 session、知识库和引用历史，对话中段切换不丢上下文。",
    href: "/zh-cn/docs/explore/chat-workspace/",
  },
  {
    chapter: "II",
    title: "Co-Writer",
    body: "双栏 Markdown 工作台，AI 是一等公民协作者。选中、改写、扩展，全部基于你的知识库。",
    href: "/zh-cn/docs/explore/co-writer/",
  },
  {
    chapter: "III",
    title: "Book Engine",
    body: "多 agent 流水线把你的材料编成可交互的「活书」—— 13 种 block，含 GeoGebra viewer 和动画。",
    href: "/zh-cn/docs/explore/book/",
  },
  {
    chapter: "IV",
    title: "知识库",
    body: "端到端 LlamaIndex 的带版本管理 RAG 文档库。每一次（重新）索引都可追溯、可对比、可回滚。",
    href: "/zh-cn/docs/explore/knowledge/",
  },
  {
    chapter: "V",
    title: "Space",
    body: "你的个人图书馆 —— chat history、notebook、question bank、自定义 skill。每个活跃界面的「阅读 / 回顾」对偶面。",
    href: "/zh-cn/docs/explore/space/",
  },
  {
    chapter: "VI",
    title: "记忆系统",
    body: "Append-only 的 L1 trace、带引用的 L2 精炼事实、跨界面综合的 L3。Memory Graph 让你随时审计 DeepTutor 为什么知道某件事。",
    href: "/zh-cn/docs/explore/memory/",
  },
];

const installs = [
  {
    id: "pypi",
    label: "PyPI",
    tag: "推荐",
    cmd: "pip install -U deeptutor",
    blurb: "最顺滑的路径：完整本地 Web 应用 + CLI，无需 clone。",
    code: `# 1. 准备一个工作区目录
mkdir -p my-deeptutor && cd my-deeptutor

# 2. 安装、配置、启动
pip install -U deeptutor
deeptutor init
deeptutor start`,
    foot: "然后打开 127.0.0.1:3782",
    href: "/zh-cn/docs/get-started/pypi/",
  },
  {
    id: "docker",
    label: "Docker",
    tag: "单容器",
    cmd: "docker run … ghcr.io/hkuds/deeptutor",
    blurb: "单容器跑完整 Web 应用，镜像来自 GitHub Container Registry。",
    code: `docker run --rm --name deeptutor \\
  -p 127.0.0.1:3782:3782 \\
  -p 127.0.0.1:8001:8001 \\
  -v deeptutor-data:/app/data \\
  ghcr.io/hkuds/deeptutor:latest`,
    foot: "记得同时映射 3782（UI）和 8001（API）。数据持久化在命名 volume 里。",
    href: "/zh-cn/docs/get-started/docker/",
  },
  {
    id: "source",
    label: "源码",
    tag: "贡献者",
    cmd: "git clone … && pip install -e .",
    blurb: "前端热重载、后端可改、完全对齐 CI。",
    code: `git clone https://github.com/HKUDS/DeepTutor.git
cd DeepTutor

python3 -m venv .venv && source .venv/bin/activate
pip install -e .
( cd web && npm ci --legacy-peer-deps )

deeptutor init && deeptutor start`,
    foot: "Python 3.11+ · Node.js 22 LTS。Next.js 以 dev 模式运行 ./web。",
    href: "/zh-cn/docs/get-started/from-source/",
  },
  {
    id: "cli",
    label: "CLI",
    tag: "无头",
    cmd: "pip install -e ./packaging/deeptutor-cli",
    blurb: "面向无界面服务器、agent harness、Claude Code / Codex 等场景的轻量安装。",
    code: `git clone https://github.com/HKUDS/DeepTutor.git
cd DeepTutor

python3 -m venv .venv-cli && source .venv-cli/bin/activate
pip install -e ./packaging/deeptutor-cli

deeptutor init --cli
deeptutor chat`,
    foot: "没有后端 / 前端端口。Embedding 默认关闭 —— 用 RAG 时再开启。",
    href: "/zh-cn/docs/get-started/cli-only/",
  },
];

---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DeepTutor —— Agent-native 的开源个性化学习伴侣</title>
    <meta
      name="description"
      content="开源 AI 学习伴侣。五种模式，一个工作区。专属 TutorBot。知识驱动的学习。"
    />
    <link rel="icon" type="image/png" href="/logo.png" />
    <script is:inline>
      (() => {
        const key = "starlight-theme";
        const resolve = (preference) =>
          preference === "light" || preference === "dark"
            ? preference
            : window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
        let stored = "auto";
        try {
          const value = localStorage.getItem(key);
          stored = value === "light" || value === "dark" ? value : "auto";
        } catch {}
        document.documentElement.dataset.theme = resolve(stored);
      })();
    </script>
  </head>
