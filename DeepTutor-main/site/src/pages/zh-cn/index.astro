        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 28px 28px;
        gap: 28px;
      }
      .dt-greeting {
        display: inline-flex;
        align-items: center;
        gap: 14px;
      }
      .dt-greeting-mark {
        width: 36px;
        height: 36px;
      }
      .dt-greeting h3 {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(28px, 3.6vw, 38px);
        font-weight: 500;
        letter-spacing: -0.022em;
        color: var(--ink);
        font-variation-settings: "opsz" 36;
      }
      .dt-composer {
        width: 100%;
        max-width: 620px;
        background: var(--paper);
        border: 1px solid var(--rule-strong);
        border-radius: 14px;
        padding: 14px 16px 10px;
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.6) inset, 0 8px 24px -16px rgba(24, 24, 28, 0.18);
        transition: border-color 0.18s ease, box-shadow 0.18s ease;
      }
      .dt-composer:focus-within {
        border-color: var(--accent);
        box-shadow: 0 0 0 4px var(--accent-soft);
      }
      .dt-composer-input {
        width: 100%;
        border: 0;
        outline: 0;
        resize: none;
        background: transparent;
        font-family: inherit;
        font-size: 14.5px;
        line-height: 1.5;
        color: var(--ink);
        padding: 4px 0 6px;
      }
      .dt-composer-input::placeholder {
        color: var(--ink-faint);
      }
      .dt-composer-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
      }
      .dt-composer-spacer {
        flex: 1;
      }
      .dt-pill {
        appearance: none;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: 999px;
        height: 28px;
        padding: 0 10px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink);
        cursor: pointer;
        transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
      }
      .dt-pill svg {
        width: 12px;
        height: 12px;
        color: var(--ink-soft);
      }
      .dt-pill:hover {
        border-color: var(--rule-strong);
      }
      .dt-pill-caret {
        opacity: 0.6;
      }
      .dt-pill-mode {
        background: rgba(77, 143, 191, 0.08);
        border-color: rgba(77, 143, 191, 0.28);
        color: var(--accent);
      }
      .dt-pill-mode svg {
        color: var(--accent);
      }
      .dt-pill-mode:hover {
        background: rgba(77, 143, 191, 0.14);
        transform: translateY(-1px);
      }
      .dt-pill-mode.is-pulsing {
        animation: dt-pulse 0.45s ease;
      }
      @keyframes dt-pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.04); }
        100% { transform: scale(1); }
      }
      .dt-model-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: linear-gradient(135deg, #d8a974, #c8865e);
        box-shadow: 0 0 0 2px rgba(216, 169, 116, 0.18);
      }
      .dt-send {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 0;
        background: rgba(216, 169, 116, 0.35);
        color: var(--paper);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.18s ease, transform 0.15s ease;
      }
      .dt-send svg {
        width: 13px;
        height: 13px;
      }
      .dt-send:hover {
        background: var(--accent);
        transform: translateY(-1px);
      }
      .dt-send.is-active {
        background: var(--ink);
      }
      .dt-mode-hint {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--ink-faint);
        letter-spacing: 0.02em;
        opacity: 0.7;
      }
      .dt-mode-hint strong {
        color: var(--accent);
        font-weight: 600;
      }
      @media (max-width: 760px) {
        .dt-app {
          height: 520px;
        }
        .dt-topbar-actions .dt-act:nth-child(-n + 2) {
          display: none;
        }
      }
      @media (max-width: 560px) {
        .dt-topbar-actions .dt-act span:not(.dt-act-glyph) {
          display: none;
        }
        .dt-pill .dt-pill-label {
          display: none;
        }
        .dt-pill {
          padding: 0 8px;
        }
        .dt-pill-mode .dt-pill-label {
          display: inline;
        }
      }

      /* ───────── Dark theme polish ───────── */
      [data-theme="dark"] .nav {
        background: rgba(13, 13, 16, 0.78);
      }
      [data-theme="dark"] .showcase-chrome {
        background: rgba(22, 22, 26, 0.7);
      }
      [data-theme="dark"] .hero-wordmark {
        filter: invert(1) hue-rotate(180deg) brightness(1.12);
      }
      [data-theme="dark"] .showcase-frame {
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.04) inset,
          0 40px 80px -44px rgba(0, 0, 0, 0.7);
      }
      [data-theme="dark"] .btn-primary:hover,
      [data-theme="dark"] .dt-send.is-active:hover {
        background: #f1ede4;
        color: #0d0d10;
      }
      [data-theme="dark"] .feature:hover,
      [data-theme="dark"] .eco-row:hover,
      [data-theme="dark"] .dt-tool:hover {
        background: rgba(123, 190, 234, 0.08);
      }
      [data-theme="dark"] .install-code {
        background: rgba(22, 22, 26, 0.74);
      }
      [data-theme="dark"] .install-tabs {
        background: rgba(241, 237, 228, 0.045);
        border-color: rgba(241, 237, 228, 0.06);
      }
      [data-theme="dark"] .install-tab.is-active {
        background: rgba(241, 237, 228, 0.1);
        box-shadow:
          0 1px 1px rgba(0, 0, 0, 0.2),
          0 2px 8px -2px rgba(0, 0, 0, 0.3);
      }
      [data-theme="dark"] .dt-act,
      [data-theme="dark"] .dt-composer,
      [data-theme="dark"] .dt-pill {
        border-color: var(--rule);
      }

      /* ───────── Footer ───────── */
      .footer {
        max-width: 1280px;
        margin: 96px auto 0;
        padding: 64px 32px 48px;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 48px;
        margin-bottom: 64px;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--ink);
        align-self: start;
      }
      .footer-brand img {
        width: 32px;
        height: 32px;
      }
      .footer-brand span {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 500;
        font-size: 22px;
      }
      .footer-cols {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
      }
      .footer-col h4 {
        margin: 0 0 16px;
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }
      .footer-col a {
        display: block;
        margin-bottom: 10px;
        text-decoration: none;
        color: var(--ink-soft);
        font-size: 14px;
        transition: color 0.15s ease;
      }
      .footer-col a:hover {
        color: var(--ink);
      }
      .footer-rule {
        height: 1px;
        background: var(--rule);
        margin-bottom: 28px;
      }

      /* ───────── Footer credo — tagline + heartbeat, centered ───────── */
      .footer-credo {
        text-align: center;
        margin: 0 0 32px;
      }
      .footer-tagline {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.25;
        color: var(--ink);
        margin: 0 0 14px;
        font-variation-settings: "opsz" 32;
      }
      .footer-tagline em {
        font-style: italic;
        font-weight: 400;
        color: var(--ink-soft);
      }

      /* ───────── Heartbeat (single editorial line, mono) ───────── */
      .footer-pulse {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        gap: 7px;
        font-family: var(--font-mono);
        font-size: 11.5px;
        letter-spacing: 0.02em;
        color: var(--ink-faint);
        opacity: 1;
        transition: opacity 0.35s ease;
      }
      .footer-pulse[data-hidden="true"] {
        opacity: 0;
        pointer-events: none;
        position: absolute;
      }
      .footer-pulse-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-soft);
        animation: dtPulse 2.4s ease-in-out infinite;
      }
      @keyframes dtPulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.45; transform: scale(0.85); }
      }
      .footer-pulse .sep {
        color: var(--ink-faint);
        opacity: 0.5;
      }
      .footer-pulse .num {
        color: var(--ink-soft);
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      .footer-pulse .num > [data-pulse] {
        color: var(--ink);
      }
      .footer-pulse-tag {
        color: var(--ink) !important;
        font-weight: 600;
        text-decoration: none !important;
        border-bottom: 1px solid var(--rule);
        padding-bottom: 1px;
        transition: border-color 0.15s ease;
      }
      .footer-pulse-tag:hover {
        border-color: var(--ink);
      }

      .footer-fine {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--ink-faint);
        letter-spacing: 0.02em;
      }
      .footer-fine a {
        color: var(--ink-soft);
        text-decoration: none;
      }
      .footer-fine a:hover {
        color: var(--ink);
      }
      @media (max-width: 720px) {
        .footer-inner {
          grid-template-columns: 1fr;
          gap: 32px;
        }
        .footer-cols {
          grid-template-columns: repeat(2, 1fr);
          gap: 24px;
        }
        .footer-fine {
          flex-direction: column;
          gap: 8px;
        }
      }
    </style>

    <script>
      // ───────── GitHub star count ─────────
      (() => {
        const targets = document.querySelectorAll<HTMLElement>("[data-gh-stars]");
        if (!targets.length) return;
        const cacheKey = "deeptutor-gh-stars";
        const ttl = 60 * 60 * 1000; // 1h
        const format = (n: number) =>
          n >= 1000 ? (n / 1000).toFixed(n >= 10000 ? 1 : 2).replace(/\.?0+$/, "") + "k" : String(n);
        const paint = (n: number) => {
          const text = format(n);
          targets.forEach((el) => (el.textContent = text));
        };
        try {
          const raw = localStorage.getItem(cacheKey);
          if (raw) {
            const cached = JSON.parse(raw);
            if (cached && typeof cached.n === "number" && Date.now() - cached.t < ttl) {
              paint(cached.n);
            }
          }
        } catch {}
        fetch("https://api.github.com/repos/HKUDS/DeepTutor")
          .then((r) => (r.ok ? r.json() : null))
          .then((data) => {
            if (!data || typeof data.stargazers_count !== "number") return;
            paint(data.stargazers_count);
            try {
              localStorage.setItem(
                cacheKey,
                JSON.stringify({ n: data.stargazers_count, t: Date.now() }),
              );
            } catch {}
          })
          .catch(() => {});
      })();

      // ───────── Install tabs ─────────
      const installRoot = document.getElementById("install");
      if (installRoot) {
        const tabs = installRoot.querySelectorAll<HTMLButtonElement>(".install-tab");
        const panels = installRoot.querySelectorAll<HTMLElement>(".install-panel");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const target = tab.dataset.target;
            tabs.forEach((t) => {
              const on = t === tab;
              t.classList.toggle("is-active", on);
              t.setAttribute("aria-selected", on ? "true" : "false");
            });
            panels.forEach((p) => {
              p.classList.toggle("is-active", p.dataset.panel === target);
            });
          });
        });
      }

      // ───────── Landing preferences ─────────
      const themeKey = "starlight-theme";
      const themeQuery = "(prefers-color-scheme: light)";
      const readThemePreference = () => {
        try {
          const stored = localStorage.getItem(themeKey);
          return stored === "light" || stored === "dark" ? stored : "auto";
        } catch {
          return "auto";
        }
      };
      const resolvedTheme = (preference: string) => {
        if (preference === "light" || preference === "dark") return preference;
        return window.matchMedia(themeQuery).matches ? "light" : "dark";
      };
      const applyThemePreference = (preference: string) => {
        document.documentElement.dataset.theme = resolvedTheme(preference);
        document.querySelectorAll<HTMLSelectElement>("[data-theme-select]").forEach((select) => {
          select.value = preference;
        });
      };
      const persistThemePreference = (preference: string) => {
        try {
          if (preference === "light" || preference === "dark") {
            localStorage.setItem(themeKey, preference);
          } else {
            localStorage.setItem(themeKey, "");
          }
        } catch {}
      };

      applyThemePreference(readThemePreference());

      document.querySelectorAll<HTMLSelectElement>("[data-theme-select]").forEach((select) => {
        select.addEventListener("change", () => {
          persistThemePreference(select.value);
          applyThemePreference(select.value);
        });
      });

      window.matchMedia(themeQuery).addEventListener("change", () => {
        if (readThemePreference() === "auto") applyThemePreference("auto");
      });

      document.querySelectorAll<HTMLSelectElement>("[data-locale-select]").forEach((select) => {
        select.addEventListener("change", () => {
          const nextPath = select.value;
          if (nextPath && nextPath !== window.location.pathname) {
            window.location.assign(`${nextPath}${window.location.search}${window.location.hash}`);
          }
        });
      });
    </script>
  </body>
</html>
