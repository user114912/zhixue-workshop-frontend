---
import Default from "@astrojs/starlight/components/SocialIcons.astro";

const path = Astro.url.pathname;
const pageURL = `https://deeptutor.info${path}`;
const issueURL = `https://github.com/HKUDS/DeepTutor/issues/new?template=docs.yml&page=${encodeURIComponent(
  pageURL,
)}`;
// WeChat community lives in a pinned GitHub issue (current QR-code thread).
const wechatURL = "https://github.com/HKUDS/DeepTutor/issues/78";
---

<div class="dt-actions">
  <a
    class="dt-report"
    href={issueURL}
    target="_blank"
    rel="noopener"
    title="Report a docs issue on this page"
  >
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="12"></line>
      <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </svg>
    <span>Report issue</span>
  </a>
  <Default><slot /></Default>
  <a
    class="sl-flex dt-wechat social-icons"
    href={wechatURL}
    target="_blank"
    rel="noopener"
    aria-label="WeChat community"
    title="WeChat community"
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M8.69 4C4.55 4 1.2 6.68 1.2 10c0 1.86 1.04 3.51 2.69 4.61l-.7 2.4 2.79-1.5c.83.3 1.74.49 2.7.49.34 0 .67-.02 1-.06-.13-.46-.21-.94-.21-1.43 0-3.07 2.97-5.5 6.7-5.5.33 0 .67.02 1 .07C16.39 6.32 12.86 4 8.69 4ZM6.18 8.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm5 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm5 1c-3.3 0-6 2.24-6 5s2.7 5 6 5c.74 0 1.45-.12 2.1-.34L20.2 20l-.7-2.05c1.07-.95 1.7-2.15 1.7-3.45 0-2.76-2.7-5-6-5Zm-2 4a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Zm4 0a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z"
      />
    </svg>
  </a>
</div>

<script is:inline>
  (() => {
    if (window.__dtLocaleSwitcherPatched) return;
    window.__dtLocaleSwitcherPatched = true;

    const zhPrefix = "/zh-cn";
    const isZhPath = (path) => path === zhPrefix || path.startsWith(`${zhPrefix}/`);
    const toEnglishPath = (path) => {
      if (path === zhPrefix || path === `${zhPrefix}/`) return "/";
      return isZhPath(path) ? path.slice(zhPrefix.length) || "/" : path;
    };
    const toChinesePath = (path) => {
      if (isZhPath(path)) return path;
      return path === "/" ? `${zhPrefix}/` : `${zhPrefix}${path}`;
    };
    const withCurrentSuffix = (path) =>
      `${path}${window.location.search}${window.location.hash}`;

    const syncLanguageSelects = () => {
      const current = window.location.pathname;
      const englishPath = toEnglishPath(current);
      const chinesePath = toChinesePath(current);
      document.querySelectorAll("starlight-lang-select select").forEach((select) => {
        Array.from(select.options).forEach((option) => {
          const label = option.textContent?.trim();
          if (label === "English") option.value = englishPath;
          if (label === "简体中文") option.value = chinesePath;
        });
        select.value = isZhPath(current) ? chinesePath : englishPath;
      });
    };

    document.addEventListener(
      "change",
      (event) => {
        const target = event.target;
        if (!(target instanceof HTMLSelectElement)) return;
        if (!target.closest("starlight-lang-select")) return;
        event.preventDefault();
        event.stopImmediatePropagation();
        const nextPath = target.value;
        if (nextPath && nextPath !== window.location.pathname) {
          window.location.assign(withCurrentSuffix(nextPath));
        }
      },
      true,
    );

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", syncLanguageSelects);
    } else {
      syncLanguageSelects();
    }
    window.addEventListener("pageshow", syncLanguageSelects);
  })();
</script>

<style>
  .dt-actions {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .dt-report {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-family:
      "Geist",
      -apple-system,
      sans-serif;
    font-size: 12.5px;
    font-weight: 500;
    line-height: 1;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
    white-space: nowrap;
  }
  .dt-report:hover {
    color: var(--sl-color-text);
    border-color: var(--sl-color-text);
    background: var(--sl-color-accent-low);
  }
  .dt-report svg {
    flex-shrink: 0;
  }
  /* Hide the "Report issue" label on narrow viewports, keep the icon */
  @media (max-width: 50rem) {
    .dt-report span {
      display: none;
    }
    .dt-report {
      padding: 5px 7px;
    }
  }
  /* WeChat icon — matches Starlight's other social icons (link color +
     same sizing). The .social-icons class taps into Starlight's existing
     hover/sizing rules; we just ensure consistent layout. */
  .dt-wechat {
    color: var(--sl-color-text);
    padding: 0.5em;
    margin: -0.5em;
  }
  .dt-wechat:hover {
    color: var(--sl-color-text);
  }
</style>
